<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <!-- Dot + connecting line column -->
    <LinearLayout
        android:layout_width="24dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <View
            android:id="@+id/timelineDot"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/dot_outline_purple"/>

        <View
            android:id="@+id/timelineLine"
            android:layout_width="2dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp"
            android:background="@color/timeline_line"/>
    </LinearLayout>

    <!-- Text content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:layout_marginBottom="18dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvClassTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="9:00 - 9-55 AM"
                android:textColor="@color/text_gray"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvClassSubject"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Data Structures"
                android:textColor="@color/text_charcoal"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvClassProfRoom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Prof. Name · Room"
                android:textColor="@color/text_gray"
                android:textSize="13sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvNewBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:background="@drawable/bg_badge_new"
            android:text="NEW"
            android:textColor="@color/card_white"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:visibility="gone"/>
    </LinearLayout>
</LinearLayout>